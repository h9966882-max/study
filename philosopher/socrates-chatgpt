  .part-sub {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    margin-top: 0.2rem;
    font-family: 'DM Mono', monospace;
  }

  /* ===== SECTION ===== */
  .section {
    margin-bottom: 3rem;
  }

  h2 {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--ink);
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--green);
    letter-spacing: -0.01em;
  }

  h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 1.8rem 0 0.8rem;
  }

  p {
    font-size: 0.92rem;
    margin-bottom: 1rem;
