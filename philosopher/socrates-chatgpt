  ul.clean li:last-child { border-bottom: none; }

  ul.clean li::before {
    content: '→';
    color: var(--green);
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* ===== QUOTE ===== */
  .quote {
    margin: 1.5rem 0;
    padding: 1.2rem 1.5rem;
    background: var(--surface);
    border-left: 4px solid var(--green);
    font-size: 0.95rem;
    color: #222;
    line-height: 1.8;
    border-radius: 0 6px 6px 0;
  }

  /* ===== DEEP BOX ===== */
  .deep-box {
    margin: 1.5rem 0;
    padding: 1.4rem;
    border: 1px dashed var(--green);
    border-radius: 6px;
    background: var(--green-pale);
  }

  .deep-box-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--green);
