  .toc-part {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--green);
    background: var(--green-light);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  /* ===== LAYOUT ===== */
  .content {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
  }

  /* ===== PART HEADER ===== */
  .part-header {
    margin: 3rem 0 1.5rem;
    padding: 1.2rem 1.5rem;
    background: var(--ink);
    color: #fff;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .part-num {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--green);
    line-height: 1;
    flex-shrink: 0;
  }

  .part-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
