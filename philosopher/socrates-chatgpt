  }

  /* ===== FACT / INTERP BOXES ===== */
  .fact-box {
    margin: 1.2rem 0;
    background: var(--fact-bg);
    border: 1px solid rgba(16,163,127,0.25);
    border-radius: 6px;
    padding: 1.2rem 1.4rem;
  }

  .interp-box {
    margin: 1.2rem 0;
    background: var(--interp-bg);
    border: 1px solid rgba(196,127,23,0.25);
    border-radius: 6px;
    padding: 1.2rem 1.4rem;
  }

  .box-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    margin-bottom: 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .fact-box .box-label { color: var(--green); }
  .interp-box .box-label { color: var(--warn); }

  .box-label::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .fact-box .box-label::before { background: var(--green); }
  .interp-box .box-label::before { background: var(--warn); }

  /* ===== TABLE ===== */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .data-table thead {
    background: var(--ink);
    color: #fff;
  }

  .data-table th {
    padding: 0.6rem 1rem;
    text-align: left;
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .data-table td {
    padding: 0.6rem 1rem;
    border-top: 1px solid var(--border);
    color: #333;
  }

  .data-table tbody tr:nth-child(even) { background: var(--bg); }

  .ok { color: var(--green); font-weight: 500; }
  .ng { color: #c44; font-weight: 500; }

  /* ===== DIALOGUE ===== */
  .dialogue {
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
  }

  .dialogue-head {
    background: var(--ink);
    color: #fff;
    padding: 0.5rem 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  .dialogue-body { padding: 1.2rem; }

  .d-step {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1rem;
    align-items: flex-start;
  }

  .d-step:last-child { margin-bottom: 0; }

  .d-arrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--green);
    flex-shrink: 0;
    padding-top: 0.15rem;
    min-width: 28px;
  }

  .d-text {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #333;
  }

  .d-text strong { color: var(--ink); font-weight: 500; }

  /* ===== LIST ===== */
  ul.clean {
    list-style: none;
    margin: 0.8rem 0 1.2rem;
  }

  ul.clean li {
    font-size: 0.9rem;
    color: #333;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
