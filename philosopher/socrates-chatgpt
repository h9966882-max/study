  }

  .hero-lead {
    font-size: 1rem;
    color: #444;
    max-width: 580px;
    line-height: 1.9;
    border-left: 3px solid var(--green);
    padding-left: 1rem;
    margin-top: 1.5rem;
  }

  /* ===== NOTICE BOX ===== */
  .notice {
    max-width: 760px;
    margin: 2rem auto 0;
    padding: 0 2rem;
  }

  .notice-inner {
    background: var(--warn-light);
    border: 1px solid rgba(196,127,23,0.3);
