<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ソクラテス講義 — Grok版</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@400;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #1a1a1a;
    --ink: #e8e8e8;
    --muted: #666;
    --border: #2a2a2a;
    --red: #e04444;
    --red-dim: rgba(224,68,68,0.12);
    --red-border: rgba(224,68,68,0.25);
    --fact-bg: rgba(255,255,255,0.04);
    --fact-border: rgba(255,255,255,0.1);
    --interp-bg: rgba(224,68,68,0.06);
    --interp-border: rgba(224,68,68,0.2);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 300;
    line-height: 1.9;
  }

  /* ===== BACK ===== */
  .back-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .back-link {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--red);
    text-decoration: none;
    transition: opacity 0.2s;
    letter-spacing: 0.03em;
  }
  .back-link:hover { opacity: 0.7; }
  .back-sep { color: var(--border); }
  .back-current { font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--muted); }

  .ai-pill {
    margin-left: auto;
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--red);
    border: 1px solid var(--red-border);
    padding: 0.2rem 0.6rem;
  }

  /* ===== HERO ===== */
  .hero {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 4rem 2rem 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: 'SOCRATES';
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: clamp(4rem, 12vw, 8rem);
    color: rgba(224,68,68,0.05);
    letter-spacing: -0.02em;
    white-space: nowrap;
    pointer-events: none;
    line-height: 1;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.2em;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--red);
  }

  h1 {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .hero-en {
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }

  .hero-quote {
    border-left: 2px solid var(--red);
    padding: 0.8rem 1.2rem;
    font-family: 'Space Mono', monospace;
    font-style: italic;
    font-size: 0.8rem;
    color: rgba(232,232,232,0.7);
    line-height: 1.8;
    max-width: 560px;
    margin-bottom: 1.5rem;
  }

  .level-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .level-pill {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border);
    color: var(--muted);
  }

  /* ===== CONTENT ===== */
  .content {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
  }

  /* ===== LEVEL ===== */
  .level-block {
    margin-bottom: 3.5rem;
  }

  .level-num-header {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .level-num {
    font-family: 'Space Mono', monospace;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--red);
    line-height: 1;
    opacity: 0.4;
  }

  .level-info {}

  .level-badge {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--red);
    margin-bottom: 0.2rem;
  }

  .level-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
  }

  /* ===== FACT / INTERP ===== */
  .fact-block {
    background: var(--fact-bg);
    border: 1px solid var(--fact-border);
    padding: 1.3rem 1.5rem;
    margin-bottom: 1rem;
  }

  .interp-block {
    background: var(--interp-bg);
    border: 1px solid var(--interp-border);
    padding: 1.3rem 1.5rem;
    margin-bottom: 1rem;
  }

  .block-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .fact-block .block-label { color: rgba(255,255,255,0.4); }
  .interp-block .block-label { color: var(--red); }

  .block-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.3;
  }

  ul.mono-list {
    list-style: none;
  }

  ul.mono-list li {
    font-size: 0.87rem;
    color: rgba(232,232,232,0.8);
    padding: 0.45rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    display: flex;
    gap: 0.8rem;
    line-height: 1.75;
  }

  ul.mono-list li:last-child { border-bottom: none; }

  ul.mono-list li::before {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .fact-block ul.mono-list li::before {
    content: '//';
    color: rgba(255,255,255,0.2);
  }

  .interp-block ul.mono-list li::before {
    content: '→';
    color: var(--red);
  }

  .block-text {
    font-size: 0.87rem;
    color: rgba(232,232,232,0.8);
    line-height: 1.85;
  }

  .block-text strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* ===== DEEP ===== */
  .deep-section {
    margin-top: 3rem;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .deep-head {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .deep-head-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--red);
  }

  .deep-head-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
  }

  .deep-body { padding: 1.5rem; }

  .deep-theme {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }

  /* insight rows */
  .insight-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.87rem;
  }

  .insight-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .insight-key {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--red);
    letter-spacing: 0.08em;
    padding-top: 0.15rem;
    line-height: 1.6;
  }

  .insight-val {
    color: rgba(232,232,232,0.8);
    line-height: 1.8;
  }

  .insight-val strong { color: var(--ink); font-weight: 500; }

  /* modern */
  .modern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.8rem;
    margin: 1rem 0;
  }

  .modern-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 0.9rem 1rem;
    font-size: 0.8rem;
    color: rgba(232,232,232,0.7);
    line-height: 1.6;
  }

  .modern-card-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    color: var(--red);
    letter-spacing: 0.15em;
    margin-bottom: 0.4rem;
  }

  /* refs */
  .ref-box {
    margin-top: 1.5rem;
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 1.2rem 1.5rem;
  }

  .ref-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 0.8rem;
  }

  .ref-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ref-list li {
    font-size: 0.8rem;
    color: rgba(232,232,232,0.5);
    display: flex;
    gap: 0.6rem;
  }

  .ref-list li::before {
    font-family: 'Space Mono', monospace;
    content: '—';
    color: var(--muted);
    flex-shrink: 0;
  }

  /* closing quote */
  .closing-quote {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--red-dim);
    border: 1px solid var(--red-border);
    font-family: 'Space Mono', monospace;
    font-style: italic;
    font-size: 0.78rem;
    color: rgba(224,68,68,0.9);
    line-height: 1.9;
    text-align: center;
  }

  /* ===== FOOTER ===== */
  .foot-nav {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .foot-nav a {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--red);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .foot-nav a:hover { opacity: 0.6; }

  .foot-center {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  @media (max-width: 600px) {
    .hero { padding: 2.5rem 1.2rem 2.5rem; }
    .content { padding: 1.5rem 1.2rem 4rem; }
    .insight-row { grid-template-columns: 1fr; gap: 0.3rem; }
    .insight-key { padding-top: 0; }
  }
</style>
</head>
